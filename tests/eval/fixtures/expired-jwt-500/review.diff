diff --git a/src/main/java/example/security/JwtService.java b/src/main/java/example/security/JwtService.java
index 1111111..2222222 100644
--- a/src/main/java/example/security/JwtService.java
+++ b/src/main/java/example/security/JwtService.java
@@ -18,9 +18,17 @@ public class JwtService {
+    @Value("${jwt.expiration-ms}")
+    private long expirationMs;
+
     public String generateToken(UserDetails user) {
         return Jwts.builder()
                 .subject(user.getUsername())
                 .issuedAt(new Date())
+                .expiration(new Date(System.currentTimeMillis() + expirationMs))
                 .signWith(signingKey)
                 .compact();
     }

+    public String extractSubject(String token) {
+        return Jwts.parser().verifyWith(signingKey).build()
+                .parseSignedClaims(token).getPayload().getSubject();
+    }
 }
