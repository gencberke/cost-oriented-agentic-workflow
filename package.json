{
  "name": "cost-oriented-agentic-workflow",
  "version": "0.5.0",
  "private": true,
  "description": "Structural checks for the cost-oriented-agentic-workflow plugin (zero runtime dependencies).",
  "type": "module",
  "scripts": {
    "check": "node tests/validate-structure.mjs",
    "test:scripts": "node scripts/run-bash.mjs tests/scripts.test.sh",
    "test:foundation": "node tests/state.test.mjs && node tests/repo-intake.test.mjs",
    "test:agents": "node tests/agent-contracts.test.mjs",
    "test:profile": "node tests/profile.test.mjs",
    "test:report": "node tests/implementation-report.test.mjs",
    "test:review-report": "node tests/review-report.test.mjs",
    "test:unit-worktree": "node tests/unit-worktree.test.mjs",
    "test:discovery-stream": "node tests/discovery-stream.test.mjs",
    "test:implementation-stream": "node tests/implementation-stream.test.mjs",
    "test:review-stream": "node tests/review-stream.test.mjs",
    "test:eval": "node scripts/run-bash.mjs tests/eval/run-tests.sh",
    "test": "node tests/validate-structure.mjs && node scripts/run-bash.mjs tests/scripts.test.sh",
    "release:build": "node scripts/build-runtime-package.mjs",
    "test:release": "node tests/release-gate.test.mjs && node tests/release-artifact.test.mjs",
    "test:hooks": "node tests/hooks.test.mjs",
    "test:enforcement": "node tests/hook-enforcement.test.mjs",
    "test:phase6": "node tests/phase6.test.mjs",
    "verify:all": "npm run check && npm run test:scripts && npm run test:hooks && npm run test:enforcement && npm run test:phase6 && npm run test:eval && npm run test:release",
    "clean:generated:dry": "node scripts/clean-generated.mjs",
    "clean:generated": "node scripts/clean-generated.mjs --apply",
    "runtime:build": "node scripts/build-runtime-package.mjs",
    "runtime:inspect": "node scripts/inspect-runtime-package.mjs",
    "release:check:candidate": "node scripts/release-gate.mjs --mode=candidate",
    "release:check:final": "node scripts/release-gate.mjs --mode=final",
    "release:version:dry": "node scripts/version-finalize.mjs --target 0.5.0 --dry-run"
  },
  "license": "MIT"
}
