#!/usr/bin/env bash
# DEPRECATED: Legacy SessionStart wrapper for compatibility.
# Scheduled for removal in Phase 7 (v0.5.0 release).
# Delegates directly to the Node hook script.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

node "${PLUGIN_ROOT}/skills/execution-routing/scripts/cow-hook.mjs" session-start
exit 0
